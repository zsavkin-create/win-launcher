{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinLauncher",
  "version": "0.1.0",
  "identifier": "com.winlauncher.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "WinLauncher",
        "width": 640,
        "height": 480,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}